/* macOS system-wide key bindings (Cocoa text system).
 * Deployed to ~/Library/KeyBindings/DefaultKeyBinding.dict by dev-env.
 * Modifiers: ^ Control, ~ Option, $ Shift, @ Command, # numeric keypad.
 * Applies to standard text fields across native apps and Chromium browsers
 * (Brave/Chrome address bar + inputs). Restart apps to pick up changes.
 */
{
    /* Ctrl+W deletes the previous word, everywhere (not just the terminal). */
    "^w" = "deleteWordBackward:";
}
